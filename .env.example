# Copy to `.env.local` for local development (never commit real secrets).

# OpenRouter — create a key at https://openrouter.ai/keys
# Used server-side by `app/api/chat/route.ts` to call models through the OpenAI-compatible API.
OPENROUTER_API_KEY=

# Model slug from https://openrouter.ai/models (copy the exact id, e.g. anthropic/claude-3.5-sonnet-20240620).
# If you see "No endpoints found", try a dated variant, add credits, or relax privacy:
# https://openrouter.ai/settings/privacy (disable "Zero data retention endpoints only" if enabled).
# Default in code is qwen/qwen-2.5-coder-32b-instruct:free — override to any slug from openrouter.ai/models
OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct:free

# Optional: public site URL for OpenRouter request attribution (HTTP-Referer).
# Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000
